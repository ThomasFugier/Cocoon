{
  "cli": {
    "appVersionSource": "remote",
    "version": ">= 16.0.1"
  },
  "build": {
    "development": {
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "CHANGE_ME_ASC_APP_ID",
        "appleTeamId": "CHANGE_ME_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "@secret:GOOGLE_SERVICE_ACCOUNT",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
