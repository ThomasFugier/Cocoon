#!/bin/sh
set -e

if [ "$WESPICE_SKIP_VERSION_BUMP" = "1" ]; then
  exit 0
fi

if git diff --cached --quiet; then
  exit 0
fi

if git diff --cached --name-only | grep -Eq '^(package\.json|package-lock\.json|app\.json|src/version\.ts)$'; then
  exit 0
fi

node scripts/version-project.js bump patch --stage

