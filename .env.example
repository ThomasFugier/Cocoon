EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optionnel: réactive le mode test/local dans un build production interne.
# Ne pas définir à true pour les builds App Store / Google Play publics.
EXPO_PUBLIC_ENABLE_LOCAL_MODE=false

# Supabase Edge Function secret, à configurer avec:
# supabase secrets set REVENUECAT_SECRET_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REVENUECAT_SECRET_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret pour appeler notify-scheduled depuis un scheduler/cron:
# supabase secrets set SUPABASE_NOTIFICATION_SECRET=notif_xxxxxxxxxxxxxxxxx
SUPABASE_NOTIFICATION_SECRET=notif_xxxxxxxxxxxxxxxxx

# Optionnel si tu actives la sécurité renforcée Expo Push:
# supabase secrets set EXPO_ACCESS_TOKEN=xxxxxxxxxxxxxxxxx
EXPO_ACCESS_TOKEN=xxxxxxxxxxxxxxxxx
