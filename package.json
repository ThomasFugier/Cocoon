{
  "name": "wespice",
  "version": "1.0.11",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-notifications": "~56.0.18",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-purchases": "^10.4.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "version:show": "node scripts/version-project.js show",
    "version:set": "node scripts/version-project.js set",
    "version:patch": "node scripts/version-project.js bump patch",
    "version:build": "node scripts/version-project.js bump patch",
    "version:prod": "node scripts/version-project.js bump minor",
    "version:major": "node scripts/version-project.js bump major",
    "version:hooks": "git config core.hooksPath .githooks",
    "build:dev": "npm run version:build && npx eas-cli@latest build --profile development",
    "build:dev:ios": "npm run version:build && npx eas-cli@latest build -p ios --profile development",
    "build:dev:android": "npm run version:build && npx eas-cli@latest build -p android --profile development",
    "build:prod": "npm run version:prod && npx eas-cli@latest build --profile production",
    "build:prod:ios": "npm run version:prod && npx eas-cli@latest build -p ios --profile production",
    "build:prod:android": "npm run version:prod && npx eas-cli@latest build -p android --profile production",
    "cards:generate": "node scripts/generate-desires.js",
    "cards:check": "node scripts/generate-desires.js --check",
    "test": "node --test tests/*.test.mjs"
  },
  "private": true
}
